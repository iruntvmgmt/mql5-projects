//@version=6
// @description Advanced rendering engine for volume profiles and market structure
// ✅ FIX v1: renderSinglePrints — added lane_color param (was hardcoded purple)
// ✅ FIX v2: renderSinglePrints — loosened neighbor gate (AND→OR, 0.1→0.05)
// ✅ NEW v5: renderMergedFastLanes — replaces the dual renderSinglePrints calls in main indicator
//            Merges consecutive sub-threshold bins into single zone boxes.
//            Enforces min_stack gate, performs fill-check against current price.
//            Eliminates the 20-40 per-bin box explosion on wide-range sessions.
// ✅ FIX v6: renderMergedFastLanes — added zone_start_i >= 0 guard on the
//            end-of-array emit block. When a zone closed and reset (zone_start_i=-1)
//            exactly on the final loop iteration, zone_len remained >0 and the
//            post-loop block fired on a stale -1 index → array.get(keys,-1) is
//            undefined behaviour in Pine, producing phantom boxes at wrong price
//            levels and silently consuming box budget.

library("GodTier_Rendering", true)

// =============================================================================
// TYPE DEFINITIONS
// =============================================================================

export type RenderConfig
    bool   use_heatmap
    bool   use_polyline
    bool   smooth_polyline
    string disp_mode
    float  profile_width_pct
    int    max_rows
    color  cold_color
    color  hot_color
    color  poly_color
    color  bull_color
    color  bear_color

export type ProfileVisuals
    box[]      profile_boxes
    polyline[] polylines
    line[]     level_lines
    box[]      zone_boxes
    label[]    labels

export type LevelConfig
    bool  show_poc
    bool  show_vah
    bool  show_val
    bool  show_va_box
    bool  show_session_box
    color poc_color
    color vah_color
    color val_color
    color va_box_color
    color session_box_color
    int   poc_width
    int   vah_width
    int   val_width
    int   box_border_width

// =============================================================================
// HELPER FUNCTIONS
// =============================================================================

// @function Converts bin index to price (internal helper)
f_get_price_from_index(int idx, float bin_sz) =>
    float safe_bin = na(bin_sz) or bin_sz <= 0 ? syminfo.mintick : bin_sz
    idx * safe_bin

// @function Safe array minimum
safe_array_min(int[] arr) =>
    array.size(arr) > 0 ? array.min(arr) : 0

// @function Safe array maximum
safe_array_max(int[] arr) =>
    array.size(arr) > 0 ? array.max(arr) : 0

// =============================================================================
// PROFILE RENDERING - CORE ENGINE
// =============================================================================

// @function Renders volume profile using box-based visualization
// @param keys         Sorted array of bin indices
// @param vol_map      Volume distribution map
// @param buy_map      Buy volume map
// @param sell_map     Sell volume map
// @param config       Render configuration
// @param left_x       Left boundary bar index
// @param prof_width   Profile width in bars
// @param bin_size     Bin size
// @param max_volume   Maximum volume for scaling
// @returns Array of profile boxes
export renderProfileBars(int[] keys, map<int, float> vol_map, map<int, float> buy_map,
                         map<int, float> sell_map, RenderConfig config, int left_x,
                         int prof_width, float bin_size, float max_volume) =>
    box[] boxes = array.new<box>()

    if array.size(keys) > 0 and max_volume > 0
        int   total_rows = array.size(keys)
        int   row_skip   = math.max(1, math.floor(total_rows / config.max_rows))
        float buffer     = bin_size / 10

        for i = 0 to total_rows - 1
            if i % row_skip != 0
                continue

            int   idx      = array.get(keys, i)
            float price    = f_get_price_from_index(idx, bin_size)
            float vol      = map.get(vol_map, idx)

            if vol > 0
                float intensity   = vol / max_volume
                int   bar_length  = math.round(intensity * prof_width)
                int   bar_end     = left_x + bar_length
                float buy_vol     = nz(map.get(buy_map, idx))
                float sell_vol    = nz(map.get(sell_map, idx))
                float buy_ratio   = vol > 0 ? buy_vol / vol : 0.5

                color bar_color = color.white
                if config.use_heatmap
                    bar_color := color.from_gradient(intensity, 0, 1, config.cold_color, config.hot_color)
                else
                    bar_color := buy_vol > sell_vol ? config.bull_color : config.bear_color

                if config.disp_mode == 'Mode 2'
                    int split_point = left_x + math.round(buy_ratio * bar_length)
                    array.push(boxes, box.new(left=left_x, top=price+buffer, right=split_point,
                        bottom=price-bin_size+buffer, border_width=0, bgcolor=color.new(config.bull_color, 50)))
                    array.push(boxes, box.new(left=split_point, top=price+buffer, right=bar_end,
                        bottom=price-bin_size+buffer, border_width=0, bgcolor=color.new(config.bear_color, 50)))

                else if config.disp_mode == 'Mode 1'
                    array.push(boxes, box.new(left=left_x, top=price+buffer, right=bar_end,
                        bottom=price-bin_size+buffer, border_width=0, bgcolor=bar_color))

                else // Mode 3: Mirrored
                    array.push(boxes, box.new(left=left_x, top=price+buffer, right=bar_end,
                        bottom=price-bin_size+buffer, border_width=0, bgcolor=color.new(config.bull_color, 50)))
                    int red_start = left_x - math.round((1 - buy_ratio) * bar_length)
                    array.push(boxes, box.new(left=red_start, top=price+buffer, right=left_x,
                        bottom=price-bin_size+buffer, border_width=0, bgcolor=color.new(config.bear_color, 50)))

    boxes

// =============================================================================
// POLYLINE RENDERING - ORGANIC MODE
// =============================================================================

// @function Renders volume profile using smooth polyline
// @param keys         Sorted array of bin indices
// @param vol_map      Volume distribution map
// @param buy_map      Buy volume map
// @param config       Render configuration
// @param left_x       Left boundary bar index
// @param prof_width   Profile width in bars
// @param bin_size     Bin size
// @param max_volume   Maximum volume for scaling
// @returns Polyline object
export renderProfilePolyline(int[] keys, map<int, float> vol_map, map<int, float> buy_map,
                              RenderConfig config, int left_x, int prof_width,
                              float bin_size, float max_volume) =>
    polyline result = na

    if array.size(keys) > 0 and max_volume > 0
        array<chart.point> points = array.new<chart.point>()

        float total_buy_vol  = 0.0
        float total_sell_vol = 0.0

        for i = 0 to array.size(keys) - 1
            int   idx   = array.get(keys, i)
            float b_vol = nz(map.get(buy_map, idx))
            float vol   = map.get(vol_map, idx)
            float s_vol = vol - b_vol
            total_buy_vol  += b_vol
            total_sell_vol += s_vol

        color poly_line_color = config.poly_color
        if total_buy_vol > total_sell_vol * 1.2
            poly_line_color := color.new(config.bull_color, 0)
        else if total_sell_vol > total_buy_vol * 1.2
            poly_line_color := color.new(config.bear_color, 0)

        array.push(points, chart.point.from_index(left_x,
            f_get_price_from_index(safe_array_min(keys), bin_size)))

        for i = 0 to array.size(keys) - 1
            int   idx        = array.get(keys, i)
            float price      = f_get_price_from_index(idx, bin_size)
            float vol        = map.get(vol_map, idx)
            float render_vol = vol

            if config.smooth_polyline and i > 0 and i < array.size(keys) - 1
                float prev_vol = map.get(vol_map, array.get(keys, i-1))
                float next_vol = map.get(vol_map, array.get(keys, i+1))
                render_vol := (prev_vol + vol + next_vol) / 3.0

            float intensity  = render_vol / max_volume
            int   bar_length = math.round(intensity * prof_width)
            int   x_coord    = left_x + bar_length
            array.push(points, chart.point.from_index(x_coord, price))

        array.push(points, chart.point.from_index(left_x,
            f_get_price_from_index(safe_array_max(keys), bin_size)))

        result := polyline.new(points, line_color=poly_line_color, line_width=2,
            fill_color=color.new(poly_line_color, 95))

    result

// =============================================================================
// HEATMAP OVERLAY
// =============================================================================

// @function Renders heatmap boxes behind profile bars
// @param keys         Sorted array of bin indices
// @param vol_map      Volume distribution map
// @param left_x       Left boundary bar index
// @param prof_width   Profile width in bars
// @param bin_size     Bin size
// @param max_volume   Maximum volume for scaling
// @param cold_color   Cold gradient color
// @param hot_color    Hot gradient color
// @returns Array of heatmap boxes
export renderHeatmap(int[] keys, map<int, float> vol_map, int left_x, int prof_width,
                     float bin_size, float max_volume, color cold_color, color hot_color) =>
    box[] heatmap_boxes = array.new<box>()

    if array.size(keys) > 0 and max_volume > 0
        float buffer = bin_size / 10

        for i = 0 to array.size(keys) - 1
            int   idx   = array.get(keys, i)
            float price = f_get_price_from_index(idx, bin_size)
            float vol   = map.get(vol_map, idx)

            if vol > 0
                float intensity  = vol / max_volume
                int   bar_length = math.round(intensity * prof_width)
                int   x_coord    = left_x + bar_length
                color heat_col   = color.from_gradient(intensity, 0, 1, cold_color, hot_color)

                array.push(heatmap_boxes, box.new(left=left_x, top=price+buffer, right=x_coord,
                    bottom=price-bin_size+buffer, border_color=na, bgcolor=heat_col))

    heatmap_boxes

// =============================================================================
// LEVEL LINES - POC, VAH, VAL
// =============================================================================

// @function Renders POC, VAH, VAL lines
// @param poc     Point of Control price
// @param vah     Value Area High
// @param val     Value Area Low
// @param config  Level configuration
// @param left_x  Left boundary
// @param right_x Right boundary
// @returns Array of level lines
export renderLevels(float poc, float vah, float val, LevelConfig config,
                    int left_x, int right_x) =>
    line[] lines = array.new<line>()

    if config.show_poc and not na(poc)
        array.push(lines, line.new(x1=left_x, y1=poc, x2=right_x, y2=poc,
            color=config.poc_color, width=config.poc_width))

    if config.show_vah and not na(vah)
        array.push(lines, line.new(x1=left_x, y1=vah, x2=right_x, y2=vah,
            color=config.vah_color, width=config.vah_width, style=line.style_dashed))

    if config.show_val and not na(val)
        array.push(lines, line.new(x1=left_x, y1=val, x2=right_x, y2=val,
            color=config.val_color, width=config.val_width, style=line.style_dashed))

    lines

// =============================================================================
// BOXES - SESSION & VALUE AREA
// =============================================================================

// @function Renders session boundary box
// @param left_x  Left boundary
// @param right_x Right boundary
// @param high    Session high
// @param low     Session low
// @param config  Level configuration
// @returns Session box
export renderSessionBox(int left_x, int right_x, float high, float low,
                        LevelConfig config) =>
    box session_box = na
    if config.show_session_box
        session_box := box.new(left=left_x, top=high, right=right_x, bottom=low,
            border_color=chart.fg_color, border_width=config.box_border_width,
            border_style=line.style_dashed, bgcolor=config.session_box_color)
    session_box

// @function Renders Value Area box
// @param left_x  Left boundary
// @param right_x Right boundary
// @param vah     Value Area High
// @param val     Value Area Low
// @param config  Level configuration
// @returns Value Area box
export renderValueAreaBox(int left_x, int right_x, float vah, float val,
                          LevelConfig config) =>
    box va_box = na
    if config.show_va_box and not na(vah) and not na(val)
        va_box := box.new(left=left_x, top=vah, right=right_x, bottom=val,
            border_color=color.rgb(54, 58, 69, 100), bgcolor=config.va_box_color)
    va_box

// =============================================================================
// PATTERN ZONES - LVN, IMBALANCES
// =============================================================================

// @function Renders Low Volume Nodes (LVN) markers
// @param keys        Sorted array of bin indices
// @param vol_map     Volume distribution map
// @param left_x      Left boundary
// @param prof_width  Profile width
// @param bin_size    Bin size
// @param max_volume  Maximum volume
// @param threshold   LVN threshold (0–1)
// @param lvn_color   Color for LVN boxes
// @returns Array of LVN boxes
export renderLVNs(int[] keys, map<int, float> vol_map, int left_x, int prof_width,
                  float bin_size, float max_volume, float threshold, color lvn_color) =>
    box[] lvn_boxes = array.new<box>()

    if array.size(keys) > 0
        float buffer      = bin_size / 10
        int   start_point = left_x + prof_width

        for i = 0 to array.size(keys) - 1
            int   idx   = array.get(keys, i)
            float vol   = map.get(vol_map, idx)
            float price = f_get_price_from_index(idx, bin_size)

            if vol < (max_volume * threshold) and vol > 0
                array.push(lvn_boxes, box.new(left=start_point, top=price+buffer,
                    right=bar_index+10, bottom=price-bin_size+buffer,
                    border_width=1, border_color=lvn_color,
                    bgcolor=color.new(lvn_color, 85)))

    lvn_boxes

// =============================================================================
// FAST LANES - MERGED ZONE RENDERER (v5 NEW)
// =============================================================================

// @function Renders Fast Lane / Single Print zones with merged adjacent bins.
//           Replaces the per-bin renderSinglePrints approach.
//           Groups consecutive sub-threshold bins into single contiguous zone boxes.
//           Enforces a minimum zone width in bins (min_stack) to suppress noise.
//           Performs a fill-check — skips zones that current price is trading through.
//
// @param keys           Sorted array of bin indices (ascending).
// @param vol_map        Volume distribution map.
// @param left_x         Left boundary (profile right edge).
// @param right_x        Right boundary (current bar).
// @param bin_size       Bin size.
// @param max_volume     Maximum volume in profile for scaling threshold.
// @param threshold      Volume fraction of max_volume below which a bin qualifies (e.g. 0.15).
// @param lane_color     Fill color for zone boxes.
// @param min_stack      Minimum consecutive qualifying bins to emit a zone (default 2).
// @param current_price  Current price for fill-check. Pass na to skip fill-check.
// @returns Array of merged fast lane zone boxes.
export renderMergedFastLanes(int[] keys, map<int, float> vol_map, int left_x, int right_x,
                              float bin_size, float max_volume, float threshold,
                              color lane_color, simple int min_stack = 2,
                              float current_price = na) =>
    box[] lane_boxes = array.new<box>()
    int   key_count  = array.size(keys)

    if key_count >= min_stack and max_volume > 0
        float half_bin      = bin_size / 2
        int   zone_start_i  = -1   // index into keys[] where current run began
        int   zone_len      = 0

        for i = 0 to key_count - 1
            int   idx       = array.get(keys, i)
            float vol       = nz(map.get(vol_map, idx))
            bool  qualifies = vol < (max_volume * threshold)

            if qualifies
                if zone_start_i < 0
                    zone_start_i := i
                zone_len += 1
            else
                // Zone broken — emit if it meets min_stack
                if zone_len >= min_stack
                    int   sk        = array.get(keys, zone_start_i)
                    int   ek        = array.get(keys, zone_start_i + zone_len - 1)
                    float zone_top  = f_get_price_from_index(ek, bin_size) + half_bin
                    float zone_bot  = f_get_price_from_index(sk, bin_size) - half_bin
                    bool  is_filled = not na(current_price) and
                                      current_price >= zone_bot and
                                      current_price <= zone_top
                    if not is_filled
                        array.push(lane_boxes, box.new(
                            left         = left_x,
                            top          = zone_top,
                            right        = right_x,
                            bottom       = zone_bot,
                            border_width = 0,
                            bgcolor      = lane_color
                        ))
                zone_start_i := -1
                zone_len     := 0

        // Handle zone still open at end of key array
        // ✅ FIX v6: Added zone_start_i >= 0 guard — without it, a zone that was
        //    just closed and reset (zone_start_i = -1) on the last iteration could
        //    fire this block with a stale zone_len > 0, producing a phantom box at
        //    price level idx*bin_size for key index -1 (undefined behaviour / wrong price).
        if zone_len >= min_stack and zone_start_i >= 0
            int   sk        = array.get(keys, zone_start_i)
            int   ek        = array.get(keys, zone_start_i + zone_len - 1)
            float zone_top  = f_get_price_from_index(ek, bin_size) + half_bin
            float zone_bot  = f_get_price_from_index(sk, bin_size) - half_bin
            bool  is_filled = not na(current_price) and
                              current_price >= zone_bot and
                              current_price <= zone_top
            if not is_filled
                array.push(lane_boxes, box.new(
                    left         = left_x,
                    top          = zone_top,
                    right        = right_x,
                    bottom       = zone_bot,
                    border_width = 0,
                    bgcolor      = lane_color
                ))

    lane_boxes

// =============================================================================
// LEGACY SINGLE-PRINT RENDERER — KEPT FOR BACKWARD COMPATIBILITY
// Use renderMergedFastLanes in new code.
// =============================================================================

// @function Renders Fast Lane / Single Print (liquidity void) zones
// @deprecated Use renderMergedFastLanes() instead. Retained only for backward
//             compatibility with any external scripts that may import this library.
//             Main indicator replaced dual renderSinglePrints calls with a single
//             renderMergedFastLanes pass (v9.1 / Rendering v5). Do not add new
//             call sites.
//
// @param keys        Sorted array of bin indices
// @param vol_map     Volume distribution map
// @param left_x      Left boundary (profile end)
// @param right_x     Right boundary (current bar)
// @param bin_size    Bin size
// @param max_volume  Maximum volume
// @param threshold   Fast lane threshold — bin must be below this fraction of max_volume
// @param lane_color  Color for fast lane boxes (default: purple)
// @returns Array of fast lane boxes
//
// ✅ FIX 1: Added lane_color parameter — was hardcoded color.purple, ignoring c_fast_lane input
// ✅ FIX 2: Neighbor gate changed from AND (both > 10%) to OR (either > 5%)
// PATCH v9.9.6: Marked @deprecated — not called by main indicator since v9.1.
export renderSinglePrints(int[] keys, map<int, float> vol_map, int left_x, int right_x,
                          float bin_size, float max_volume, float threshold,
                          color lane_color = color.purple) =>
    box[] sp_boxes = array.new<box>()

    if array.size(keys) > 2
        for i = 1 to array.size(keys) - 2
            int   idx  = array.get(keys, i)
            float vol  = map.get(vol_map, idx)

            if vol < (max_volume * threshold)
                float prev = map.get(vol_map, array.get(keys, i - 1))
                float next = map.get(vol_map, array.get(keys, i + 1))

                if prev > (max_volume * 0.05) or next > (max_volume * 0.05)
                    float price = f_get_price_from_index(idx, bin_size)
                    array.push(sp_boxes, box.new(
                        left         = left_x,
                        top          = price + bin_size / 2,
                        right        = right_x,
                        bottom       = price - bin_size / 2,
                        border_width = 0,
                        bgcolor      = color.new(lane_color, 70)
                    ))

    sp_boxes

// @function Renders stacked imbalance zones
// @param keys             Sorted array of bin indices
// @param buy_map          Buy volume map
// @param sell_map         Sell volume map
// @param vol_map          Total volume map
// @param left_x           Left boundary
// @param right_x          Right boundary
// @param bin_size         Bin size
// @param imbalance_ratio  Minimum ratio for imbalance
// @param min_stack        Minimum consecutive bins
// @returns Array of imbalance zone boxes
export renderImbalances(int[] keys, map<int, float> buy_map, map<int, float> sell_map,
                        map<int, float> vol_map, int left_x, int right_x, float bin_size,
                        float imbalance_ratio, int min_stack) =>
    box[] imb_boxes = array.new<box>()
    int   span_end  = math.max(right_x, bar_index + 5)

    if array.size(keys) > 0
        int   consec         = 0
        float sequence_start = na

        for i = 0 to array.size(keys) - 1
            int   idx   = array.get(keys, i)
            float price = f_get_price_from_index(idx, bin_size)
            float b_vol = nz(map.get(buy_map, idx))
            float s_vol = nz(map.get(sell_map, idx))
            float vol   = nz(map.get(vol_map, idx))

            if vol <= 0
                consec := 0
                continue

            bool is_imb = s_vol > 0 ? (b_vol / s_vol > imbalance_ratio or b_vol / s_vol < (1 / imbalance_ratio)) : (b_vol > 0)

            if is_imb
                if consec == 0
                    sequence_start := price
                consec += 1
            else
                if consec >= min_stack
                    array.push(imb_boxes, box.new(left=left_x, top=sequence_start+bin_size,
                        right=span_end, bottom=price, border_color=color.new(color.orange, 50),
                        border_width=1, bgcolor=color.new(color.orange, 85)))
                consec := 0

        if consec >= min_stack and not na(sequence_start)
            array.push(imb_boxes, box.new(left=left_x, top=sequence_start+bin_size,
                right=span_end,
                bottom=f_get_price_from_index(array.get(keys, array.size(keys)-1), bin_size),
                border_color=color.new(color.orange, 50), border_width=1,
                bgcolor=color.new(color.orange, 85)))

    imb_boxes

// =============================================================================
// SESSION LABELS
// =============================================================================

// @function Creates or updates session label
// @param existing_label  Current label (or na)
// @param bar_x           X position
// @param price_y         Y position
// @param session_type    Session name
// @param profile_shape   Profile shape string
// @param rotation        Rotation factor
// @param show_rotation   Whether to show rotation
// @returns Label object
export updateSessionLabel(label existing_label, int bar_x, float price_y,
                          string session_type, string profile_shape,
                          float rotation, bool show_rotation) =>
    string lbl_text = session_type + " (Live)\n" + profile_shape
    if show_rotation
        lbl_text += "\nRot: " + str.tostring(rotation, "#.##")

    if na(existing_label)
        label.new(x=bar_x, y=price_y, text=lbl_text, color=color.rgb(0,0,0,100),
            textcolor=chart.fg_color, style=label.style_label_down,
            size=size.small, xloc=xloc.bar_index)
    else
        label.set_text(existing_label, lbl_text)
        label.set_y(existing_label, price_y)
        label.set_x(existing_label, bar_x)
        existing_label

// =============================================================================
// CLEANUP UTILITIES
// =============================================================================

// @function Cleans up old box drawing objects
// @param boxes Array of boxes to delete
export cleanupBoxes(box[] boxes) =>
    for b in boxes
        box.delete(b)
    array.clear(boxes)

// @function Cleans up old line drawing objects
// @param lines Array of lines to delete
export cleanupLines(line[] lines) =>
    for l in lines
        line.delete(l)
    array.clear(lines)

// @function Cleans up old polyline drawing objects
// @param polylines Array of polylines to delete
export cleanupPolylines(polyline[] polylines) =>
    while array.size(polylines) > 0
        polyline.delete(array.shift(polylines))

// @function Cleans up old label drawing objects
// @param labels Array of labels to delete
export cleanupLabels(label[] labels) =>
    for lbl in labels
        label.delete(lbl)
    array.clear(labels)
